# ==============================================
# OneDigital Advisor Intelligence Suite
# Environment Configuration
# ==============================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/advisor_db
DB_MIGRATE=true

# Server
NODE_ENV=production
PORT=3000
SESSION_SECRET=your-secret-key-min-32-chars-here

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo
AI_RATE_LIMIT=100

# Optional Integrations (leave blank to disable)
SALESFORCE_ENABLED=false
SALESFORCE_CLIENT_ID=
SALESFORCE_PRIVATE_KEY=
SALESFORCE_INSTANCE_URL=

ORION_ENABLED=false                # boolean — enable Orion integration
ORION_API_KEY=                     # string  — Orion API bearer token
ORION_BASE_URL=                    # string  — Orion API base URL (default: https://api.orionadvisor.com/api/v1)
ORION_TIMEOUT=30000                # integer — request timeout in ms (default: 30000)
ORION_RETRY_COUNT=3                # integer — max retry attempts on failure (default: 3)
ORION_REP_CODE=                    # string  — Orion rep code (e.g. MGouldin). Filters 35K portfolios → ~500 for this advisor. Requires MuleSoft EAPI ?repCode= passthrough.
PORTFOLIO_SYNC_INTERVAL=14400000   # integer — background sync interval in ms (default: 14400000 / 4 hours)

BLACK_DIAMOND_ENABLED=false
BLACK_DIAMOND_CLIENT_ID=
BLACK_DIAMOND_CLIENT_SECRET=
BLACK_DIAMOND_BASE_URL=

MULESOFT_ENABLED=false               # boolean — enable MuleSoft WAD integration
MULESOFT_AUTH_URL=                    # string  — FULL OAuth2 token endpoint URL (include path, e.g. https://od-auth-service-uat-dgm3vs.63g8ag.usa-e1.cloudhub.io/v1.0/oauth2/token)
MULESOFT_CLIENT_ID=                  # string  — OAuth2 client ID
MULESOFT_CLIENT_SECRET=              # string  — OAuth2 client secret
MULESOFT_SCOPE=                      # string  — OAuth2 scope (e.g. https://graph.microsoft.com/.default)
MULESOFT_API_BASE_URL=               # string  — WAD EAPI base URL, host only, NO trailing slash (e.g. https://od-wad-eapi-dev-t0nidn.63g8ag.usa-e1.cloudhub.io)
ACTIVE_PORTFOLIO_PROVIDER=orion      # string  — active portfolio provider: orion | mulesoft | blackdiamond

MICROSOFT_ENABLED=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

EMAIL_ENABLED=false
SENDGRID_API_KEY=

ZOOM_ENABLED=false
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_INTEGRATIONS_ENABLED=false

# CORS (comma-separated origins, leave blank to allow all)
CORS_ORIGIN=

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=

# Session
SESSION_MAX_AGE=86400000
COOKIE_SECURE=true
COOKIE_SAME_SITE=Strict

# Cassidy AI
CASSIDY_API_KEY=
CASSIDY_ASSISTANT_ID=                # string — Cassidy assistant ID (required for direct REST mode)
CASSIDY_ORCHESTRATION_WEBHOOK_URL=   # string — Cassidy orchestration webhook URL
CASSIDY_SUBROUTER_WEBHOOK_URL=       # string — Cassidy sub-agent router URL

# Seed Data (used by server/seed.ts — never commit real credentials)
SEED_DEMO_ADVISOR_NAME=Sarah Mitchell
SEED_DEMO_ADVISOR_EMAIL=sarah.mitchell@example.com
SEED_DEMO_ADVISOR_PASSWORD=changeme123
SEED_USER_NAME=Dev Advisor
SEED_USER_EMAIL=dev.advisor@example.com
SEED_USER_PASSWORD=changeme123
SEED_UAT_ADVISOR_NAME=UAT Advisor
SEED_UAT_ADVISOR_EMAIL=uat.advisor@example.com.uat
SEED_UAT_ADVISOR_PASSWORD=changeme123
