exports[`Calculator UI Snapshots — post-calculation results > MonteCarlo shows results after simulation 1`] = `"<div style="background: rgb(240, 237, 232); min-height: 100vh; font-family: &quot;DM Sans&quot;, system-ui, sans-serif;"><div style="background: rgb(12, 18, 34); padding: 20px 28px; display: flex; align-items: center; gap: 16px;"><div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgb(107, 143, 224), rgb(59, 86, 158)); display: flex; align-items: center; justify-content: center;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FAF8F5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg></div><div><div style="font-size: 18px; font-weight: 700; letter-spacing: -0.5px; color: rgb(250, 248, 245); font-family: &quot;Cormorant Garamond&quot;, serif;">Monte Carlo Engine</div><div style="font-size: 11px; color: rgb(139, 149, 170); letter-spacing: 1.5px; font-family: &quot;DM Mono&quot;, monospace;">LOG-NORMAL GBM · CORRELATED ASSETS · 4 WITHDRAWAL STRATEGIES</div></div><div style="margin-left: auto; display: flex; align-items: center; gap: 24px;"><div style="text-align: right;"><div style="font-size: 26px; font-weight: 700; color: rgb(184, 135, 43); font-family: &quot;DM Mono&quot;, monospace;">85.6%</div><div style="font-size: 11px; color: rgb(184, 135, 43); opacity: 0.85;">On Track with Buffer</div></div><div style="width: 1px; height: 36px; background: rgb(27, 39, 64);"></div><div style="text-align: right;"><div style="font-size: 20px; font-weight: 700; color: rgb(138, 174, 240); font-family: &quot;DM Mono&quot;, monospace;">Age 92</div><div style="font-size: 11px; color: rgb(139, 149, 170);">Confidence Age (P50)</div></div></div></div><div style="display: flex; background: rgb(20, 29, 51); padding-left: 20px;"><button data-testid="tab-overview" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">OVERVIEW</button><button data-testid="tab-allocation" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">ALLOCATION</button><button data-testid="tab-cashflows" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">CASHFLOWS</button><button data-testid="tab-scenarios" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">SCENARIOS</button><button data-testid="tab-results" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor rgb(107, 143, 224); border-image: none; cursor: pointer; color: rgb(107, 143, 224); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 700;">RESULTS</button><button data-testid="button-run-simulation" style="margin: 7px 20px 7px auto; background: linear-gradient(135deg, rgb(107, 143, 224), rgb(59, 86, 158)); border: 1px solid rgb(107, 143, 224); border-radius: 8px; padding: 8px 20px; cursor: pointer; color: rgb(250, 248, 245); font-size: 12px; letter-spacing: 1.5px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 700; display: flex; align-items: center; gap: 6px;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-play"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg> RUN 5,000 SCENARIOS</button></div><div style="display: grid; grid-template-columns: 290px 1fr; min-height: calc(100vh - 110px);"><div style="border-right: 1px solid rgb(240, 237, 232); padding: 20px; overflow-y: auto; background: rgb(250, 248, 245);"><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Client Profile</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">CURRENT AGE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">58 yrs</span></div><input type="range" min="30" max="80" step="1" data-testid="slider-current-age" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="58"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">30 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">80 yrs</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">RETIREMENT AGE</span><span style="color: rgb(59, 86, 158); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">65 yrs</span></div><input type="range" min="59" max="80" step="1" data-testid="slider-retirement-age" style="width: 100%; accent-color: rgb(59, 86, 158); height: 4px; cursor: pointer;" value="65"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">59 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">80 yrs</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">LIFE EXPECTANCY</span><span style="color: rgb(61, 139, 94); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">92 yrs</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">34-year planning horizon</div><input type="range" min="75" max="105" step="1" data-testid="slider-life-expectancy" style="width: 100%; accent-color: rgb(61, 139, 94); height: 4px; cursor: pointer;" value="92"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">75 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">105 yrs</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Portfolio</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">INITIAL PORTFOLIO</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$2.0M</span></div><input type="range" min="100000" max="10000000" step="50000" data-testid="slider-initial-portfolio" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="2000000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$100K</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$10.0M</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">ANNUAL SPENDING</span><span style="color: rgb(184, 135, 43); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$120K</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">6.0% initial withdrawal rate</div><input type="range" min="20000" max="500000" step="5000" data-testid="slider-annual-spending" style="width: 100%; accent-color: rgb(184, 135, 43); height: 4px; cursor: pointer;" value="120000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$20K</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$500K</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">INFLATION RATE</span><span style="color: rgb(196, 75, 75); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">3.0%</span></div><input type="range" min="0.01" max="0.1" step="0.005" data-testid="slider-inflation-rate" style="width: 100%; accent-color: rgb(196, 75, 75); height: 4px; cursor: pointer;" value="0.03"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">1.0%</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10.0%</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">EFFECTIVE TAX RATE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">24%</span></div><input type="range" min="0.1" max="0.45" step="0.01" data-testid="slider-effective-tax-rate" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="0.24"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10%</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">45%</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Social Security</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">SS CLAIM AGE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">Age 70</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">Maximum benefit (+32% vs FRA)</div><input type="range" min="62" max="70" step="1" data-testid="slider-ss-claim-age" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="70"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">Age 62</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">Age 70</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">ANNUAL SS BENEFIT</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$42K</span></div><input type="range" min="0" max="60000" step="1000" data-testid="slider-annual-ss-benefit" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="42000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$0</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$60K</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Simulation</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">SCENARIOS</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">5,000</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">More = higher accuracy, slower</div><input type="range" min="500" max="10000" step="500" data-testid="slider-scenarios" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="5000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">500</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10,000</span></div></div><label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-top: 8px;"><input type="checkbox" data-testid="checkbox-rebalance" style="accent-color: rgb(107, 143, 224);" checked=""><span style="color: rgb(107, 111, 122); font-size: 12px;">Annual rebalancing</span></label></div></div><div style="overflow-y: auto; padding: 24px 28px;"><div><div><div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px;"><div data-testid="metric-success-rate" style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgba(184, 135, 43, 0.145); text-align: center;"><div style="color: rgb(184, 135, 43); margin-bottom: 6px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg></div><div style="color: rgb(184, 135, 43); font-weight: 700; font-size: 18px; font-family: &quot;DM Mono&quot;, monospace;">85.6%</div><div style="color: rgb(44, 47, 54); font-size: 11px; margin-top: 4px;">Success Rate</div><div style="color: rgb(155, 159, 168); font-size: 10px; margin-top: 2px;">On Track with Buffer</div></div><div data-testid="metric-confidence-age" style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgba(107, 143, 224, 0.145); text-align: center;"><div style="color: rgb(107, 143, 224); margin-bottom: 6px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div><div style="color: rgb(107, 143, 224); font-weight: 700; font-size: 18px; font-family: &quot;DM Mono&quot;, monospace;">Age 92</div><div style="color: rgb(44, 47, 54); font-size: 11px; margin-top: 4px;">Confidence Age</div><div style="color: rgb(155, 159, 168); font-size: 10px; margin-top: 2px;">P50 plan survives to</div></div><div data-testid="metric-median-terminal" style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgba(59, 86, 158, 0.145); text-align: center;"><div style="color: rgb(59, 86, 158); margin-bottom: 6px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" clas