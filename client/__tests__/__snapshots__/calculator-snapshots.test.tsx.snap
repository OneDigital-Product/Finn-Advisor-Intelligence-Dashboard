rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232);"><div style="color: rgb(44, 47, 54); font-weight: 700; margin-bottom: 14px; font-size: 13px;">Portfolio Assumptions Used</div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Expected Annual Return (mu)</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">7.5%</span></div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Annual Volatility (sig)</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">9.2%</span></div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Scenarios Run</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">5,000</span></div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Planning Horizon</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">34 years</span></div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Withdrawal Rule</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">Guyton-Klinger</span></div><div style="display: flex; justify-content: space-between; padding: 7px 0px; border-bottom: 1px solid rgb(240, 237, 232);"><span style="color: rgb(155, 159, 168); font-size: 12px;">Stress Test</span><span style="color: rgb(27, 29, 34); font-size: 12px; font-family: &quot;DM Mono&quot;, monospace;">None</span></div></div></div></div></div></div></div></div>"`;

exports[`Calculator UI Snapshots — post-calculation results > QSBSCalculatorPage shows results after calculation 1`] = `"<div class="p-6 max-w-7xl mx-auto space-y-6"><div class="flex items-center gap-4"><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="button-back-tax-strategy"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left w-4 h-4 mr-1"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg> Tax Strategy</button><div><h1 class="text-2xl font-bold" data-testid="text-page-title">QSBS Tracker</h1><p class="text-sm text-muted-foreground">Track Section 1202 qualified small business stock exclusions and holding periods</p></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm" data-testid="qsbs-holding-0"><div class="flex flex-col space-y-1.5 p-6 pb-3"><div class="flex justify-between items-center"><div class="font-semibold tracking-tight text-base">Holding 1: TechStartup Inc</div></div></div><div class="p-6 pt-0 space-y-4"><div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3"><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Company Name *</label><input class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" placeholder="Acme Corp" data-testid="input-company-name-0" value="TechStartup Inc"></div><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Ticker</label><input class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" placeholder="ACME" data-testid="input-ticker-0" value=""></div><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Shares</label><input type="number" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" min="0" data-testid="input-shares-0" value=""></div><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Cost Basis *</label><input type="number" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" min="0" step="0.01" placeholder="100000" data-testid="input-cost-basis-0" value="100000"></div><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Current Value *</label><input type="number" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" min="0" step="0.01" placeholder="500000" data-testid="input-current-value-0" value="5000000"></div><div><label class="font-medium peer-disabled:cursor-not-allowed peer-disabled:opacity-70 text-xs">Acquisition Date *</label><input type="date" class="flex h-9 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm" data-testid="input-acq-date-0" value="2020-01-15"></div></div><div class="border-t pt-3"><p class="text-xs font-medium text-muted-foreground mb-2">Eligibility Criteria</p><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"><div class="flex items-center gap-2"><button type="button" role="checkbox" aria-checked="true" data-state="checked" value="on" class="peer h-4 w-4 shrink-0 rounded-sm border border-primary ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 data-[state=checked]:bg-primary data-[state=checked]:text-primary-foreground" data-testid="checkbox-qualifiedSmallBusiness-0"><span data-state="checked" class="flex items-center justify-center text-current" style="pointer-events: none;"><svg xmlns="http://www.w3.org/2000/svg" width="24" height