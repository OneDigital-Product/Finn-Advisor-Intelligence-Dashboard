ll="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-down w-12 h-12 text-muted-foreground/30 mb-4"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline><polyline points="16 17 22 17 22 11"></polyline></svg><h3 class="text-lg font-medium mb-1" data-testid="text-empty-results">Enter parameters to calculate</h3><p class="text-sm text-muted-foreground">Fill in the form and click Calculate Budget to see results.</p></div></div></div></div></div>"`;

exports[`Calculator UI Snapshots — initial form layout > MonteCarlo renders simulator layout 1`] = `"<div style="background: rgb(240, 237, 232); min-height: 100vh; font-family: &quot;DM Sans&quot;, system-ui, sans-serif;"><div style="background: rgb(12, 18, 34); padding: 20px 28px; display: flex; align-items: center; gap: 16px;"><div style="width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgb(107, 143, 224), rgb(59, 86, 158)); display: flex; align-items: center; justify-content: center;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FAF8F5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg></div><div><div style="font-size: 18px; font-weight: 700; letter-spacing: -0.5px; color: rgb(250, 248, 245); font-family: &quot;Cormorant Garamond&quot;, serif;">Monte Carlo Engine</div><div style="font-size: 11px; color: rgb(139, 149, 170); letter-spacing: 1.5px; font-family: &quot;DM Mono&quot;, monospace;">LOG-NORMAL GBM · CORRELATED ASSETS · 4 WITHDRAWAL STRATEGIES</div></div></div><div style="display: flex; background: rgb(20, 29, 51); padding-left: 20px;"><button data-testid="tab-overview" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor rgb(107, 143, 224); border-image: none; cursor: pointer; color: rgb(107, 143, 224); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 700;">OVERVIEW</button><button data-testid="tab-allocation" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">ALLOCATION</button><button data-testid="tab-cashflows" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">CASHFLOWS</button><button data-testid="tab-scenarios" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">SCENARIOS</button><button data-testid="tab-results" style="padding: 11px 18px; background: none; border-width: medium medium 2px; border-style: none none solid; border-color: currentcolor currentcolor transparent; border-image: none; cursor: pointer; color: rgb(139, 149, 170); font-size: 12px; letter-spacing: 1px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 400;">RESULTS</button><button data-testid="button-run-simulation" style="margin: 7px 20px 7px auto; background: linear-gradient(135deg, rgb(107, 143, 224), rgb(59, 86, 158)); border: 1px solid rgb(107, 143, 224); border-radius: 8px; padding: 8px 20px; cursor: pointer; color: rgb(250, 248, 245); font-size: 12px; letter-spacing: 1.5px; font-family: &quot;DM Mono&quot;, monospace; font-weight: 700; display: flex; align-items: center; gap: 6px;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-play"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg> RUN 5,000 SCENARIOS</button></div><div style="display: grid; grid-template-columns: 290px 1fr; min-height: calc(100vh - 110px);"><div style="border-right: 1px solid rgb(240, 237, 232); padding: 20px; overflow-y: auto; background: rgb(250, 248, 245);"><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Client Profile</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">CURRENT AGE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">58 yrs</span></div><input type="range" min="30" max="80" step="1" data-testid="slider-current-age" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="58"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">30 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">80 yrs</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">RETIREMENT AGE</span><span style="color: rgb(59, 86, 158); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">65 yrs</span></div><input type="range" min="59" max="80" step="1" data-testid="slider-retirement-age" style="width: 100%; accent-color: rgb(59, 86, 158); height: 4px; cursor: pointer;" value="65"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">59 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">80 yrs</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">LIFE EXPECTANCY</span><span style="color: rgb(61, 139, 94); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">92 yrs</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">34-year planning horizon</div><input type="range" min="75" max="105" step="1" data-testid="slider-life-expectancy" style="width: 100%; accent-color: rgb(61, 139, 94); height: 4px; cursor: pointer;" value="92"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">75 yrs</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">105 yrs</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Portfolio</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">INITIAL PORTFOLIO</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$2.0M</span></div><input type="range" min="100000" max="10000000" step="50000" data-testid="slider-initial-portfolio" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="2000000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$100K</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$10.0M</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">ANNUAL SPENDING</span><span style="color: rgb(184, 135, 43); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$120K</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">6.0% initial withdrawal rate</div><input type="range" min="20000" max="500000" step="5000" data-testid="slider-annual-spending" style="width: 100%; accent-color: rgb(184, 135, 43); height: 4px; cursor: pointer;" value="120000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$20K</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$500K</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">INFLATION RATE</span><span style="color: rgb(196, 75, 75); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">3.0%</span></div><input type="range" min="0.01" max="0.1" step="0.005" data-testid="slider-inflation-rate" style="width: 100%; accent-color: rgb(196, 75, 75); height: 4px; cursor: pointer;" value="0.03"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">1.0%</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10.0%</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">EFFECTIVE TAX RATE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">24%</span></div><input type="range" min="0.1" max="0.45" step="0.01" data-testid="slider-effective-tax-rate" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="0.24"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10%</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">45%</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Social Security</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">SS CLAIM AGE</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">Age 70</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">Maximum benefit (+32% vs FRA)</div><input type="range" min="62" max="70" step="1" data-testid="slider-ss-claim-age" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="70"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">Age 62</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">Age 70</span></div></div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">ANNUAL SS BENEFIT</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">$42K</span></div><input type="range" min="0" max="60000" step="1000" data-testid="slider-annual-ss-benefit" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="42000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$0</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">$60K</span></div></div></div><div style="margin-bottom: 24px;"><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">Simulation</div><div style="margin-bottom: 18px;"><div style="display: flex; justify-content: space-between; margin-bottom: 5px;"><span style="color: rgb(107, 111, 122); font-size: 11px; letter-spacing: 0.5px; font-family: &quot;DM Mono&quot;, monospace;">SCENARIOS</span><span style="color: rgb(107, 143, 224); font-weight: 700; font-size: 13px; font-family: &quot;DM Mono&quot;, monospace;">5,000</span></div><div style="color: rgb(155, 159, 168); font-size: 11px; margin-bottom: 5px;">More = higher accuracy, slower</div><input type="range" min="500" max="10000" step="500" data-testid="slider-scenarios" style="width: 100%; accent-color: rgb(107, 143, 224); height: 4px; cursor: pointer;" value="5000"><div style="display: flex; justify-content: space-between; margin-top: 3px;"><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">500</span><span style="color: rgb(155, 159, 168); font-size: 10px; font-family: &quot;DM Mono&quot;, monospace;">10,000</span></div></div><label style="display: flex; align-items: center; gap: 8px; cursor: pointer; margin-top: 8px;"><input type="checkbox" data-testid="checkbox-rebalance" style="accent-color: rgb(107, 143, 224);" checked=""><span style="color: rgb(107, 111, 122); font-size: 12px;">Annual rebalancing</span></label></div></div><div style="overflow-y: auto; padding: 24px 28px;"><div><div style="font-size: 10px; color: rgb(139, 149, 170); letter-spacing: 2px; margin-bottom: 12px; text-transform: uppercase; font-family: &quot;DM Mono&quot;, monospace;">WHAT MAKES THIS ENGINE DIFFERENT</div><div style="display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 24px;"><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(107, 143, 224); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chart-column"><path d="M3 3v16a2 2 0 0 0 2 2h16"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">Log-Normal GBM</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Geometric Brownian Motion with correlated assets matches how real asset prices evolve.</div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(61, 139, 94); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">Correlated Assets</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Equity-bond correlation built-in. Bonds act as ballast in equity crashes.</div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(184, 135, 43); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-dollar-sign"><line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">4 Withdrawal Rules</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Fixed real, Guyton-Klinger guardrails, Floor+Upside, RMD-based strategies.</div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(59, 86, 158); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">Lifecycle Cashflows</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Model exact years for home purchase, college, business sale, or medical events.</div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(61, 139, 94); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">P10/P50/P90 Bands</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Full distribution visualization. The P10 line is where the real planning conversation lives.</div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); display: flex; gap: 14px; align-items: flex-start;"><div style="color: rgb(196, 75, 75); flex-shrink: 0; margin-top: 2px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg></div><div><div style="color: rgb(27, 29, 34); font-weight: 700; font-size: 13px; margin-bottom: 4px;">Stress Tests</div><div style="color: rgb(107, 111, 122); font-size: 12px; line-height: 1.6;">Overlay 2008 crashes, 1970s inflation, or sequence-of-returns risk on any scenario.</div></div></div></div><div style="background: rgb(250, 248, 245); border-radius: 10px; padding: 20px; border: 1px solid rgb(240, 237, 232); margin-bottom: 20px;"><div style="color: rgb(107, 143, 224); font-weight: 700; margin-bottom: 14px; font-size: 13px;">Current Plan Parameters</div><div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;"><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">PORTFOLIO</div><div style="color: rgb(107, 143, 224); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">$2.0M</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">ANNUAL SPEND</div><div style="color: rgb(184, 135, 43); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">$120K</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">WITHDRAWAL RATE</div><div style="color: rgb(196, 75, 75); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">6.0%</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">HORIZON</div><div style="color: rgb(59, 86, 158); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">34 yrs</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">SS AT AGE</div><div style="color: rgb(61, 139, 94); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">70 / $42K/yr</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">INFLATION</div><div style="color: rgb(196, 75, 75); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">3.0%</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">WITHDRAWAL RULE</div><div style="color: rgb(107, 111, 122); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">Guyton-Klinger</div></div><div style="background: rgb(240, 237, 232); border-radius: 8px; padding: 12px;"><div style="color: rgb(155, 159, 168); font-size: 10px; letter-spacing: 1px; margin-bottom: 4px; font-family: &quot;DM Mono&quot;, monospace;">TAX RATE</div><div style="color: rgb(107, 111, 122); font-weight: 700; font-size: 14px; font-family: &quot;DM Mono&quot;, monospace;">24.0%</div></div></div></div><div style="background: rgb(232, 243, 237); border-radius: 10px; padding: 20px; border: 1px solid rgba(61, 139, 94, 0.19); display: flex; align-items: center; gap: 12px;"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3D8B5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-circle-play"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg><div><div style="color: rgb(61, 139, 94); font-weight: 700; font-size: 13px;">Ready to Run</div><div style="color: rgb(45, 107, 71); font-size: 12px;">Configure allocation and cashflows, then click RUN 5,000 SCENARIOS</div></div></div></div></div></div></div>"`;

