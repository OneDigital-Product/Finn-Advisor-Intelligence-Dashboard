exports[`Client Detail UI Snapshots > DirectIndexingSection renders section header and layout 1`] = `"<div class="space-y-6" data-testid="section-direct-indexing"><div class="flex items-center justify-between"><div><h3 class="text-lg font-semibold" data-testid="text-direct-indexing-title">Direct Indexing &amp; Tax-Lot Management</h3><p class="text-sm text-muted-foreground mt-0.5">Individual security-level index tracking and tax-lot harvesting for John Doe</p></div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 bg-primary text-primary-foreground border border-primary-border min-h-8 rounded-md px-3 text-xs" data-testid="button-create-direct-index"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-4 h-4 mr-1.5"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>Create Direct Index</button></div><div class="grid gap-4 md:grid-cols-4"><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm" data-testid="card-total-lots"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layers w-4 h-4 text-blue-500"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"></path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path></svg><span class="text-xs text-muted-foreground">Tax Lots</span></div><div class="text-xl font-bold" data-testid="text-total-lots">0</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm" data-testid="card-unrealized-losses"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-down-right w-4 h-4 text-red-500"><path d="m7 7 10 10"></path><path d="M17 7v10H7"></path></svg><span class="text-xs text-muted-foreground">Unrealized Losses</span></div><div class="text-xl font-bold text-red-600 dark:text-red-400" data-testid="text-unrealized-losses">$0</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm" data-testid="card-unrealized-gains"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right w-4 h-4 text-green-500"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg><span class="text-xs text-muted-foreground">Unrealized Gains</span></div><div class="text-xl font-bold text-green-600 dark:text-green-400" data-testid="text-unrealized-gains">$0</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm" data-testid="card-harvestable-savings"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-dollar-sign w-4 h-4 text-amber-500"><line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg><span class="text-xs text-muted-foreground">Harvestable Savings</span></div><div class="text-xl font-bold text-amber-600 dark:text-amber-400" data-testid="text-harvestable-savings">$0</div></div></div></div><div class="flex gap-1.5 border-b pb-2"><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 bg-primary text-primary-foreground border border-primary-border min-h-8 rounded-md px-3 text-xs" data-testid="tab-lots"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layers w-3.5 h-3.5 mr-1.5"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"></path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path></svg>Tax Lots</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="tab-harvest"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-down w-3.5 h-3.5 mr-1.5"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"></polyline><polyline points="16 17 22 17 22 11"></polyline></svg>Harvestable Losses</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="tab-wash-sale"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert w-3.5 h-3.5 mr-1.5"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>Wash Sales</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="tab-portfolios"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target w-3.5 h-3.5 mr-1.5"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>Direct Index</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="tab-rebalance"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right-left w-3.5 h-3.5 mr-1.5"><path d="m16 3 4 4-4 4"></path><path d="M20 7H4"></path><path d="m8 21-4-4 4-4"></path><path d="M4 17h16"></path></svg>Rebalance</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border border-transparent min-h-8 rounded-md px-3 text-xs" data-testid="tab-alpha"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-dollar-sign w-3.5 h-3.5 mr-1.5"><line x1="12" x2="12" y1="2" y2="22"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>Tax Alpha</button></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 py-8 text-center text-muted-foreground"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layers w-8 h-8 mx-auto mb-2 opacity-50"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"></path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path></svg><p>No tax lots found. Tax lots will be generated from existing holdings.</p></div></div></div>"`;

exports[`Client Detail UI Snapshots > EstatePlanningSection renders section header and layout 1`] = `"<div class="space-y-6" data-testid="estate-planning-section"><div class="flex items-center justify-between"><div><h2 class="text-lg font-semibold" data-testid="text-estate-planning-title">Estate Planning</h2><p class="text-sm text-muted-foreground">Multi-generational wealth transfer and trust management</p></div><div class="flex gap-2"><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border [border-color:var(--button-outline)] shadow-xs active:shadow-none min-h-8 rounded-md px-3 text-xs" data-testid="button-add-gift"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gift w-3.5 h-3.5 mr-1.5"><rect x="3" y="8" width="18" height="4" rx="1"></rect><path d="M12 8v13"></path><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"></path></svg> Record Gift</button><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 bg-primary text-primary-foreground border border-primary-border min-h-8 rounded-md px-3 text-xs" data-testid="button-add-trust"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-3.5 h-3.5 mr-1.5"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg> Add Trust</button></div></div><div class="flex gap-1 border-b pb-px"><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors bg-primary text-primary-foreground" data-testid="tab-estate-overview">Overview</button><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50" data-testid="tab-estate-taxanalysis">Tax Analysis</button><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50" data-testid="tab-estate-trusts">Trusts</button><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50" data-testid="tab-estate-exemptions">Exemptions</button><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50" data-testid="tab-estate-gifts">Gifts</button><button class="px-3 py-1.5 text-sm font-medium rounded-t-md transition-colors text-muted-foreground hover:text-foreground hover:bg-muted/50" data-testid="tab-estate-wealthmap">Wealth Map</button></div><div class="space-y-6"><div class="grid grid-cols-1 md:grid-cols-4 gap-4"><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-landmark w-4 h-4 text-blue-600"><line x1="3" x2="21" y1="22" y2="22"></line><line x1="6" x2="6" y1="18" y2="11"></line><line x1="10" x2="10" y1="18" y2="11"></line><line x1="14" x2="14" y1="18" y2="11"></line><line x1="18" x2="18" y1="18" y2="11"></line><polygon points="12 2 20 7 4 7"></polygon></svg><span class="text-xs text-muted-foreground">Total Estate Value</span></div><div class="text-xl font-bold" data-testid="text-estate-total-value">$0</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-building2 w-4 h-4 text-purple-600"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"></path><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"></path><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"></path><path d="M10 6h4"></path><path d="M10 10h4"></path><path d="M10 14h4"></path><path d="M10 18h4"></path></svg><span class="text-xs text-muted-foreground">Trust Assets</span></div><div class="text-xl font-bold" data-testid="text-trust-total-value">$0</div><div class="text-xs text-muted-foreground mt-0.5">0 active trusts</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield w-4 h-4 text-green-600"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg><span class="text-xs text-muted-foreground">Remaining Exemption</span></div><div class="text-xl font-bold" data-testid="text-remaining-exemption">$0</div><div class="text-xs text-muted-foreground mt-0.5">of $0 limit</div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 pt-4 pb-3"><div class="flex items-center gap-2 mb-1"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gift w-4 h-4 text-amber-600"><rect x="3" y="8" width="18" height="4" rx="1"></rect><path d="M12 8v13"></path><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"></path><path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"></path></svg><span class="text-xs text-muted-foreground">Lifetime Gifts Used</span></div><div class="text-xl font-bold" data-testid="text-lifetime-gifts">$0</div></div></div></div></div></div>"`;

exports[`Client Detail UI Snapshots > RetirementSection renders section header and layout 1`] = `"<div class="grid grid-cols-1 lg:grid-cols-3 gap-6"><div class="space-y-4"><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="flex flex-col space-y-1.5 p-6 pb-3"><div class="flex items-center justify-between"><div class="font-semibold tracking-tight text-base flex items-center gap-2"><div class="w-6 h-6 rounded bg-violet-500/10 dark:bg-violet-400/10 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-3.5 h-3.5 text-violet-600 dark:text-violet-400"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg></div>Scenarios</div><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 border [border-color:var(--button-outline)] shadow-xs active:shadow-none min-h-8 rounded-md px-3 text-xs" data-testid="button-new-scenario"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-3.5 h-3.5 mr-1"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg> New</button></div></div><div class="p-6 pt-0"><div class="text-center py-6"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-8 h-8 text-muted-foreground mx-auto mb-2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg><p class="text-sm text-muted-foreground">No scenarios yet</p><p class="text-xs text-muted-foreground mt-1">Create a scenario to run Monte Carlo retirement simulations</p></div><div class="space-y-2"></div></div></div><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="flex flex-col space-y-1.5 p-6 pb-3"><div class="font-semibold tracking-tight text-base">Portfolio</div></div><div class="p-6 pt-0"><div class="text-2xl font-semibold" data-testid="text-portfolio-value">$1.50M</div><p class="text-xs text-muted-foreground mt-1">Current portfolio value used in simulation</p></div></div></div><div class="lg:col-span-2 space-y-4"><div class="shadcn-card rounded-xl border bg-card border-card-border text-card-foreground shadow-sm"><div class="p-6 py-16 text-center"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up w-12 h-12 text-muted-foreground mx-auto mb-4"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg><h3 class="text-lg font-semibold mb-2">Monte Carlo Retirement Simulation</h3><p class="text-sm text-muted-foreground max-w-md mx-auto mb-6">Run 1,000 simulated market scenarios to estimate the probability of maintaining your client's desired retirement lifestyle. Add life events like college tuition, Social Security, and medical expenses to create realistic projections.</p><button class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 hover-elevate active-elevate-2 bg-primary text-primary-foreground border border-primary-border min-h-9 px-4 py-2" data-testid="button-create-first-scenario"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus w-4 h-4 mr-2"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg> Create First Scenario</button></div></div></div></div>"`;
