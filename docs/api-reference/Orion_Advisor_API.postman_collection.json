{
  "info": {
    "_postman_id": "8f9d8083-37d6-4b47-a894-9f7b4aa6f7f4",
    "name": "Orion Advisor API",
    "description": "Starter Postman collection for Orion Advisor Cloud API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Authenticate and capture token from response.access_token or response.token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returned success status', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const token = json.access_token || json.token || json.id_token;",
                  "",
                  "if (token) {",
                  "    pm.environment.set('authToken', token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Sample Endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "List Portfolios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/portfolios?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "portfolios"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Client Total AUM",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients/39798",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients",
                "39798"
              ]
            },
            "description": "Get client total AUM for Household ID 39798"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('AUM value is present', function () {",
                  "    pm.expect(json.aum).to.be.a('number');",
                  "});",
                  "",
                  "console.log('Total AUM: $' + json.aum.toFixed(2));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Client Account Count",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients/39798/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients",
                "39798",
                "accounts"
              ]
            },
            "description": "Get all investment accounts for Household ID 39798 and display account count"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const accounts = pm.response.json();",
                  "const accountCount = Array.isArray(accounts) ? accounts.length : 0;",
                  "",
                  "pm.test('Accounts array is present', function () {",
                  "    pm.expect(accountCount).to.be.greaterThanOrEqual(0);",
                  "});",
                  "",
                  "pm.environment.set('accountCount', accountCount);",
                  "console.log('Total Account Count: ' + accountCount);",
                  "console.log('Accounts:');",
                  "accounts.forEach((acc, idx) => {",
                  "  console.log((idx + 1) + '. Custodian: ' + (acc.custodian || 'N/A') + ' | Value: $' + acc.currentValue.toFixed(2));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Portfolio Operations",
      "item": [
        {
          "name": "List All Clients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients?limit=20&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get list of all clients with pagination"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const clients = pm.response.json();",
                  "const clientCount = Array.isArray(clients) ? clients.length : 0;",
                  "",
                  "pm.test('Clients array is present', function () {",
                  "    pm.expect(clientCount).to.be.greaterThanOrEqual(0);",
                  "});",
                  "",
                  "console.log('Total Clients Retrieved: ' + clientCount);",
                  "clients.forEach((client, idx) => {",
                  "  console.log((idx + 1) + '. ' + (client.representativeName || 'N/A') + ' | AUM: $' + client.aum.toFixed(2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Client by ID (Parameterized)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients/{{clientId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients",
                "{{clientId}}"
              ]
            },
            "description": "Get specific client details by ID. Set {{clientId}} variable (e.g., 39798)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const client = pm.response.json();",
                  "pm.test('Client data is present', function () {",
                  "    pm.expect(client.aum).to.be.a('number');",
                  "});",
                  "",
                  "console.log('Client: ' + (client.representativeName || 'N/A'));",
                  "console.log('AUM: $' + client.aum.toFixed(2));",
                  "console.log('Status: ' + (client.isActive ? 'Active' : 'Inactive'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Client Accounts (Parameterized)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients/{{clientId}}/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients",
                "{{clientId}}",
                "accounts"
              ]
            },
            "description": "Get all accounts for a client. Set {{clientId}} variable"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const accounts = pm.response.json();",
                  "const totalAccounts = Array.isArray(accounts) ? accounts.length : 0;",
                  "let totalValue = 0;",
                  "",
                  "accounts.forEach(acc => {",
                  "  totalValue += acc.currentValue || 0;",
                  "});",
                  "",
                  "pm.test('Accounts array exists', function () {",
                  "    pm.expect(totalAccounts).to.be.greaterThanOrEqual(0);",
                  "});",
                  "",
                  "pm.environment.set('accountCount', totalAccounts);",
                  "console.log('Total Accounts: ' + totalAccounts);",
                  "console.log('Combined Account Value: $' + totalValue.toFixed(2));",
                  "accounts.forEach((acc, idx) => {",
                  "  console.log((idx + 1) + '. ' + (acc.custodian || 'N/A') + ' | $' + acc.currentValue.toFixed(2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Active Clients",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients?limit=50&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Get list of active clients (filter in response)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const clients = pm.response.json();",
                  "const activeClients = clients.filter(c => c.isActive === true);",
                  "",
                  "pm.test('Active clients found', function () {",
                  "    pm.expect(activeClients.length).to.be.greaterThanOrEqual(0);",
                  "});",
                  "",
                  "console.log('Total Active Clients: ' + activeClients.length);",
                  "console.log('Total Combined AUM: $' + activeClients.reduce((sum, c) => sum + c.aum, 0).toFixed(2));",
                  "activeClients.slice(0, 10).forEach((client, idx) => {",
                  "  console.log((idx + 1) + '. ' + (client.representativeName || 'N/A') + ' | AUM: $' + client.aum.toFixed(2));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/Authorization/User",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "Authorization",
                "User"
              ]
            },
            "description": "Get current authenticated user information"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json();",
                  "pm.test('User data is present', function () {",
                  "    pm.expect(user.loginUserId).to.exist;",
                  "});",
                  "",
                  "pm.environment.set('userId', user.userId);",
                  "console.log('User: ' + user.firstName + ' ' + user.lastName);",
                  "console.log('Email: ' + user.email);",
                  "console.log('Company: ' + user.alClientName);",
                  "console.log('Instance: ' + user.instanceName);"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Clients by Name",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/portfolio/clients?limit=100&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "portfolio",
                "clients"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "100"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Search clients - filter by name in post-processing (update searchTerm variable)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const clients = pm.response.json();",
                  "const searchTerm = pm.environment.get('searchTerm') || 'Demo';",
                  "const filtered = clients.filter(c => ",
                  "  (c.representativeName && c.representativeName.toLowerCase().includes(searchTerm.toLowerCase())) ||",
                  "  (c.category && c.category.toLowerCase().includes(searchTerm.toLowerCase()))",
                  ");",
                  "",
                  "console.log('Search Results for: \"' + searchTerm + '\"');",
                  "console.log('Found: ' + filtered.length + ' client(s)');",
                  "filtered.forEach((client, idx) => {",
                  "  console.log((idx + 1) + '. ' + client.representativeName + ' (' + client.category + ') | AUM: $' + client.aum.toFixed(2));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.cloud.orionadvisor.com"
    },
    {
      "key": "clientId",
      "value": "39798"
    },
    {
      "key": "searchTerm",
      "value": "Demo"
    }
  ]
}
